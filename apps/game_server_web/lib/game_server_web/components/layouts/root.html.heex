<!DOCTYPE html>
<html
  lang={Gettext.get_locale(GameServerWeb.Gettext) || "en"}
  class="scroll-smooth"
  data-theme={assigns[:color_mode]}
>
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1"
    />
    <meta name="csrf-token" content={get_csrf_token()} />
    <%!-- Tiny synchronous script to set data-theme before CSS loads (prevents FOUC) --%>
    <script phx-track-static type="text/javascript" src={~p"/assets/js/theme-init.js"}>
    </script>
    <!-- Open Graph / Twitter meta defaults -->
    <% locale = Gettext.get_locale(GameServerWeb.Gettext) %>
    <% provider_theme = GameServer.Theme.JSONConfig.get_theme(locale) || %{} %>
    <% title = assigns[:page_title] || Map.get(provider_theme, "title") %>
    <% description = assigns[:meta_description] || Map.get(provider_theme, "tagline") %>
    <% banner_path = Map.get(provider_theme, "banner", "") %>
    <% static_dir = Application.app_dir(:game_server_web, "priv/static") %>
    <% banner_dark_path = String.replace(banner_path, ~r/\.(\w+)$/, "_dark.\\1") %>
    <% banner_dark_exists? =
      banner_dark_path != "" and
        banner_dark_path != banner_path and
        File.exists?(Path.join(static_dir, String.trim_leading(banner_dark_path, "/"))) %>
    <% image_path = if banner_dark_exists?, do: banner_dark_path, else: banner_path %>

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image_path} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image_path} />
    <.live_title
      default={Map.get(provider_theme, "title")}
      prefix={"#{Map.get(provider_theme, "title")} — "}
    >
      {assigns[:page_title]}
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <%= if Map.get(provider_theme, "css") do %>
      <link rel="stylesheet" phx-track-static href={Map.get(provider_theme, "css")} />
    <% end %>
    <%= if Map.get(provider_theme, "favicon") do %>
      <link rel="icon" type="image/x-icon" href={Map.get(provider_theme, "favicon")} />
    <% end %>
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
  </head>
  <body>
    {@inner_content}
  </body>
</html>
